    "decisionRendering": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rendering_id", "summary", "recommendation", "confidence", "depends_on", "movement_jobs"],
      "properties": {
        "rendering_id": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "recommendation": {
          "type": "string"
        },
        "confidence": {
          "$ref": "#/$defs/ordinal"
        },
        "depends_on": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "movement_jobs": {
          "$ref": "#/$defs/movementJobs"
        }
      }
    },
    "validatorResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["passed", "checks"],
      "dependentRequired": {
        "diagnostics": ["checks"]
      },
      "properties": {
        "passed": {
          "type": "boolean"
        },
        "diagnostics": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/validatorDiagnostic"
          }
        },
        "checks": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["check", "passed", "notes"],
            "properties": {
              "check": {
                "type": "string"
              },
              "passed": {
                "type": "boolean"
              },
              "notes": {
                "type": "string"
              },
              "code": {
                "type": "string",
                "pattern": "^OFONE_[A-Z0-9_]+$"
              },
              "severity": {
                "enum": ["error", "warning", "info"]
              }
            }
          }
        }
      }
    },
    "validatorDiagnostic": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "severity", "check", "object_id", "object_type", "path", "message", "repair_hint"],
      "properties": {
        "code": {
          "type": "string",
          "pattern": "^OFONE_[A-Z0-9_]+$"
        },
        "severity": {
          "enum": ["error", "warning", "info"]
        },
        "check": {
          "type": "string"
        },
        "object_id": {
          "type": ["string", "null"]
        },
        "object_type": {
          "type": ["string", "null"]
        },
        "path": {
          "type": ["string", "null"]
        },
        "message": {
          "type": "string"
        },
        "repair_hint": {
          "type": ["string", "null"]
        }
      }
    },
    "reviewCycle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cycle_id", "source_review", "source_url", "round", "status", "accepted_findings", "rejected_findings", "unresolved_findings", "implemented_commits", "stop_reason", "movement_jobs"],
