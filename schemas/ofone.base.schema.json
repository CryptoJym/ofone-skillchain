{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cryptojym.github.io/ofone-skillchain/schemas/ofone.base.schema.json",
  "title": "OfOne Base Decision Map",
  "type": "object",
  "required": [
    "ofone_version",
    "mode",
    "charter",
    "adapter_projection",
    "scene",
    "evidence",
    "claims",
    "unknowns",
    "kill_tests",
    "triggers",
    "gates",
    "confidence_model",
    "decision_rendering"
  ],
  "properties": {
    "ofone_version": {
      "type": "string"
    },
    "mode": {
      "enum": ["Micro", "Map", "Audit"]
    },
    "charter": {
      "$ref": "#/$defs/charter"
    },
    "artifact_identity": {
      "$ref": "#/$defs/artifactIdentity"
    },
    "adapter_projection": {
      "$ref": "#/$defs/adapterProjection"
    },
    "scene": {
      "$ref": "#/$defs/scene"
    },
    "evidence": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidence"
      }
    },
    "claims": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/claim"
      }
    },
    "unknowns": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/unknown"
      }
    },
    "kill_tests": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/killTest"
      }
    },
    "criteria": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/criterion"
      }
    },
    "tradeoff_surface": {
      "$ref": "#/$defs/tradeoffSurface"
    },
    "actors": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/actor"
      }
    },
    "temporal_model": {
      "$ref": "#/$defs/temporalModel"
    },
    "information_value": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/informationValue"
      }
    },
    "lenses": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/lens"
      }
    },
    "council_result": {
      "$ref": "#/$defs/councilResult"
    },
    "review_log": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/reviewLogEntry"
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/edge"
      }
    },
    "loops": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/loop"
      }
    },
    "option_moves": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/optionMove"
      }
    },
    "triggers": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/trigger"
      }
    },
    "gates": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/gate"
      }
    },
    "confidence_model": {
      "$ref": "#/$defs/confidenceModel"
    },
    "decision_rendering": {
      "$ref": "#/$defs/decisionRendering"
    },
    "validator_result": {
      "$ref": "#/$defs/validatorResult"
    },
    "review_cycle": {
      "$ref": "#/$defs/reviewCycle"
    },
    "benchmark_trace": {
      "$ref": "#/$defs/benchmarkTrace"
    }
  },
  "dependentRequired": {
    "artifact_identity": ["evidence"],
    "tradeoff_surface": ["criteria", "option_moves"],
    "temporal_model": ["evidence"],
    "review_log": ["gates", "actors"]
  },
  "$defs": {
    "movementJob": {
      "enum": ["BOUND", "GROUND", "CLAIM", "LINK", "TEST", "MOVE", "EVALUATE", "WARN", "TRIGGER", "GATE"]
    },
    "ordinal": {
      "enum": ["low", "medium", "high"]
    },
    "movementJobs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/movementJob"
      }
    },
    "charter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["objective", "scope", "horizon", "stakes", "risk_tier", "movement_jobs"],
      "properties": {
        "objective": {
          "type": "string"
        },
        "scope": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "horizon": {
          "type": "string"
        },
        "stakes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "risk_tier": {
          "$ref": "#/$defs/ordinal"
        },
        "movement_jobs": {
          "$ref": "#/$defs/movementJobs"
        }
      }
    },
    "artifactIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_id", "case_id", "objective_head", "scope_hash", "config_hash", "active_evidence_hashes", "created_at", "status", "movement_jobs"],
      "properties": {
        "artifact_id": {
          "type": "string"
        },
        "case_id": {
          "type": "string"
        },
        "objective_head": {
          "type": "string"
        },
        "scope_hash": {
          "type": "string",
          "pattern": "^sha256:[a-fA-F0-9]{64}$|^unknown$"
        },
        "config_hash": {
          "type": "string",
          "pattern": "^sha256:[a-fA-F0-9]{64}$|^unknown$"
        },
        "active_evidence_hashes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "created_at": {
          "type": "string"
        },
        "status": {
          "enum": ["draft", "validated", "rendered", "review_pending", "released", "superseded"]
        },
        "movement_jobs": {
          "$ref": "#/$defs/movementJobs"
        }
      }
    },
    "adapterProjection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary", "axes", "movement_jobs"],
      "properties": {
        "primary": {
          "enum": ["strategic-agentic", "scientific-explanatory", "formal", "normative-evaluative", "hybrid", "provisional"]
        },
        "axes": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "movement_jobs": {
          "$ref": "#/$defs/movementJobs"
        }
      }
    },
    "scene": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scene_id", "frames", "tokens", "subscenes", "state_variables", "observed_variables", "hidden_variables", "movement_jobs"],
      "properties": {
        "scene_id": {
          "type": "string"
        },
        "frames": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/frame"
          }
        },
        "tokens": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/token"
          }
        },
        "subscenes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/subscene"
          }
        },
        "state_variables": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "observed_variables": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "hidden_variables": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "movement_jobs": {
          "$ref": "#/$defs/movementJobs"
        }
      }
    },
    "frame": {
      "type": "object",
      "additionalProperties": false,
      "required": ["frame_id", "type", "assumptions"],
      "properties": {
        "frame_id": {
          "type": "string"
        },
        "type": {
          "enum": ["causal", "logical", "strategic", "normative", "temporal", "evidential"]
        },
        "assumptions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "subscene": {
      "type": "object",
      "additionalProperties": false,
      "required": ["subscene_id", "parent_scene", "purpose", "frames", "tokens", "entry_conditions", "exit_conditions", "movement_jobs"],
      "properties": {
        "subscene_id": {
          "type": "string"
        },
        "parent_scene": {
          "type": "string"
        },
        "purpose": {
          "enum": ["evidence_acquisition", "causal_mechanism", "option_decision", "review_gate", "proof_step", "stakeholder_context", "other"]
        },
        "frames": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tokens": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "entry_conditions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "exit_conditions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "movement_jobs": {
          "$ref": "#/$defs/movementJobs"
        }
      }
    },
    "token": {
      "type": "object",
      "additionalProperties": false,
      "required": ["token_id", "kind", "label"],
      "properties": {
        "token_id": {
          "type": "string"
        },
        "kind": {
          "enum": ["entity", "variable", "claim", "evidence", "uncertainty", "constraint", "option", "trigger", "gate", "unknown"]
        },
        "label": {
          "type": "string"
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evidence_id", "source", "span_or_locator", "provenance", "recency", "reliability", "permission", "content_hash", "retrieved_at", "extract", "source_owner", "chain_of_custody", "supports", "risks", "movement_jobs"],
      "dependentRequired": {
        "content_hash": ["retrieved_at", "extract", "source_owner", "chain_of_custody"]
      },
      "properties": {
        "evidence_id": {
          "type": "string"
        },
        "source": {
          "enum": ["file", "url", "observation", "testimony", "simulation", "tool"]
        },
        "span_or_locator": {
          "type": "string"
        },
        "provenance": {
          "type": "string"
        },
        "recency": {
          "enum": ["current", "dated", "unknown"]
        },
        "reliability": {
          "$ref": "#/$defs/ordinal"
        },
        "permission": {
          "enum": ["internal", "public", "restricted"]
        },
        "content_hash": {
          "type": "string",
          "pattern": "^sha256:[a-fA-F0-9]{64}$|^unknown$"
        },
        "retrieved_at": {
          "type": "string"
        },
        "extract": {
          "type": "string"
        },
        "source_owner": {
          "type": "string"
        },
        "chain_of_custody": {
          "type": "string"
        },
        "supports": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "risks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "movement_jobs": {
          "$ref": "#/$defs/movementJobs"
        }
      }
    },
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claim_id", "text", "type", "supports", "contradicts", "depends_on", "confidence", "status", "review_gate", "movement_jobs"],
      "properties": {
        "claim_id": {
          "type": "string"
        },
        "text": {
          "type": "string"
        },
        "type": {
          "enum": ["descriptive", "causal", "predictive", "normative", "formal", "operational"]
        },
        "supports": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "contradicts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "depends_on": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "confidence": {
          "$ref": "#/$defs/claimConfidence"
        },
        "status": {
          "enum": ["active", "disputed", "superseded", "killed"]
        },
        "review_gate": {
          "type": "boolean"
        },
        "movement_jobs": {
          "$ref": "#/$defs/movementJobs"
        }
      }
    },
    "claimConfidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["level", "basis", "failure_modes"],
      "properties": {
        "level": {
          "$ref": "#/$defs/ordinal"
        },
        "basis": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": ["provenance", "independence", "recency", "mechanism_fit", "contradiction_load", "hidden_variable_risk", "adversarial_risk", "adapter_fit"]
          }
        },
        "failure_modes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "unknown": {
      "type": "object",
      "additionalProperties": false,
      "required": ["unknown_id", "kind", "description", "blocks", "resolution_move", "status", "movement_jobs"],
      "properties": {
        "unknown_id": {
          "type": "string"
        },
        "kind": {
          "enum": ["missing_evidence", "missing_measurement", "missing_claim", "missing_adapter", "unresolved_conflict", "unobserved_variable"]
        },
        "description": {
          "type": "string"
        },
        "blocks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "resolution_move": {
          "type": "string"
        },
        "status": {
          "enum": ["open", "resolved", "accepted_risk"]
        },
        "movement_jobs": {
          "$ref": "#/$defs/movementJobs"
        }
      }
    },
    "killTest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["test_id", "target", "test_type", "condition", "falsifies", "movement_jobs"],
      "properties": {
        "test_id": {
          "type": "string"
        },
        "target": {
          "type": "string"
        },
        "test_type": {
          "enum": ["counterexample", "measurement", "replication", "countermodel", "stakeholder_objection", "constraint_violation", "adapter_conflict"]
        },
        "condition": {
          "type": "string"
        },
        "falsifies": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "movement_jobs": {
          "$ref": "#/$defs/movementJobs"
        }
      }
    },
    "criterion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["criterion_id", "name", "kind", "priority", "threshold", "owned_by", "movement_jobs"],
      "properties": {
        "criterion_id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "kind": {
          "enum": ["constraint", "preference", "objective", "threshold"]
        },
        "priority": {
          "enum": ["must", "should", "could"]
        },
        "threshold": {
          "type": "string"
        },
        "owned_by": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "movement_jobs": {
          "$ref": "#/$defs/movementJobs"
        }
      }
    },
    "tradeoffSurface": {
      "type": "object",
      "additionalProperties": false,
      "required": ["surface_id", "options", "criteria", "dominant_option", "why", "reversal_conditions", "movement_jobs"],
      "dependentRequired": {
        "dominant_option": ["options", "criteria", "why"],
        "reversal_conditions": ["options", "criteria"]
      },
      "properties": {
        "surface_id": {
          "type": "string"
        },
        "options": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "criteria": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "dominant_option": {
          "type": "string"
        },
        "why": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "reversal_conditions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "movement_jobs": {
          "$ref": "#/$defs/movementJobs"
        }
      }
    },
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["actor_id", "label", "role", "incentives", "exposures", "authority", "legitimacy_basis", "movement_jobs"],
      "properties": {
        "actor_id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "role": {
          "enum": ["reviewer", "beneficiary", "operator", "adversary", "decision_owner", "affected_party"]
        },
        "incentives": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "exposures": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "authority": {
          "enum": ["approve", "block", "advise", "observe"]
        },
        "legitimacy_basis": {
          "type": "string"
        },
        "movement_jobs": {
          "$ref": "#/$defs/movementJobs"
        }
      }
    },
    "temporalModel": {
      "type": "object",
      "additionalProperties": false,
      "required": ["time_horizon", "decision_deadline", "evidence_validity_windows", "update_cadence", "movement_jobs"],
      "properties": {
        "time_horizon": {
          "type": "string"
        },
        "decision_deadline": {
          "type": "string"
        },
        "evidence_validity_windows": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidenceValidityWindow"
          }
        },
        "update_cadence": {
          "type": "string"
        },
        "movement_jobs": {
          "$ref": "#/$defs/movementJobs"
        }
      }
    },
    "evidenceValidityWindow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evidence_id", "valid_until", "staleness_trigger"],
      "properties": {
        "evidence_id": {
          "type": "string"
        },
        "valid_until": {
          "type": "string"
        },
        "staleness_trigger": {
          "type": "string"
        }
      }
    },
    "informationValue": {
      "type": "object",
      "additionalProperties": false,
      "required": ["unknown_id", "decision_impact", "resolution_cost", "time_to_resolve", "risk_reduction", "recommended_next_query", "movement_jobs"],
      "properties": {
        "unknown_id": {
          "type": "string"
        },
        "decision_impact": {
          "$ref": "#/$defs/ordinal"
        },
        "resolution_cost": {
          "$ref": "#/$defs/ordinal"
        },
        "time_to_resolve": {
          "type": "string"
        },
        "risk_reduction": {
          "$ref": "#/$defs/ordinal"
        },
        "recommended_next_query": {
          "type": "string"
        },
        "movement_jobs": {
          "$ref": "#/$defs/movementJobs"
        }
      }
    },
    "lens": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lens_id", "name", "adapter_axis", "questions", "claims_examined", "blind_spots", "contention", "movement_jobs"],
      "properties": {
        "lens_id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "adapter_axis": {
          "enum": ["strategic-agentic", "scientific-explanatory", "formal", "normative-evaluative", "hybrid", "provisional"]
        },
        "questions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "claims_examined": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "blind_spots": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "contention": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "movement_jobs": {
          "$ref": "#/$defs/movementJobs"
        }
      }
    },
    "councilResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["coverage", "missing_lenses", "major_dissent", "decision_effect", "movement_jobs"],
      "properties": {
        "coverage": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "missing_lenses": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "major_dissent": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "decision_effect": {
          "type": "string"
        },
        "movement_jobs": {
          "$ref": "#/$defs/movementJobs"
        }
      }
    },
    "reviewLogEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["review_id", "gate_id", "actor_id", "decision", "timestamp", "notes", "movement_jobs"],
      "properties": {
        "review_id": {
          "type": "string"
        },
        "gate_id": {
          "type": "string"
        },
        "actor_id": {
          "type": "string"
        },
        "decision": {
          "enum": ["approved", "blocked", "returned_for_evidence", "not_required"]
        },
        "timestamp": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        },
        "movement_jobs": {
          "$ref": "#/$defs/movementJobs"
        }
      }
    },
    "edge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["edge_id", "from", "to", "relation_family", "relation", "evidence_refs", "confidence", "movement_jobs"],
      "properties": {
        "edge_id": {
          "type": "string"
        },
        "from": {
          "type": "string"
        },
        "to": {
          "type": "string"
        },
        "relation_family": {
          "enum": ["causal", "evidential", "argumentative", "workflow_state"]
        },
        "relation": {
          "enum": ["causes", "constrains", "supports", "contradicts", "enables", "observes", "evaluates", "updates", "blocks", "depends_on"]
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "confidence": {
          "$ref": "#/$defs/ordinal"
        },
        "movement_jobs": {
          "$ref": "#/$defs/movementJobs"
        }
      }
    },
    "loop": {
      "type": "object",
      "additionalProperties": false,
      "required": ["loop_id", "type", "edges", "polarity", "delay", "gain", "control_points", "observable_cues", "failure_mode", "movement_jobs"],
      "properties": {
        "loop_id": {
          "type": "string"
        },
        "type": {
          "enum": ["reinforcing", "balancing", "measurement", "incentive", "learning", "contradiction", "review", "deception", "regime"]
        },
        "edges": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "polarity": {
          "enum": ["reinforcing", "balancing", "mixed", "unknown"]
        },
        "delay": {
          "enum": ["short", "medium", "long", "unknown"]
        },
        "gain": {
          "enum": ["low", "medium", "high", "unknown"]
        },
        "control_points": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "observable_cues": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "failure_mode": {
          "type": "string"
        },
        "movement_jobs": {
          "$ref": "#/$defs/movementJobs"
        }
      }
    },
    "optionMove": {
      "type": "object",
      "additionalProperties": false,
      "required": ["option_id", "move_type", "preconditions", "expected_effects", "tradeoffs", "blocking_unknowns", "review_gate", "movement_jobs"],
      "properties": {
        "option_id": {
          "type": "string"
        },
        "move_type": {
          "enum": ["act", "query", "test", "prove", "observe", "defer", "revise"]
        },
        "preconditions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "expected_effects": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tradeoffs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "blocking_unknowns": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "review_gate": {
          "type": "string"
        },
        "movement_jobs": {
          "$ref": "#/$defs/movementJobs"
        }
      }
    },
    "trigger": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trigger_id", "condition", "affected_objects", "transition", "movement_jobs"],
      "properties": {
        "trigger_id": {
          "type": "string"
        },
        "condition": {
          "enum": ["new_evidence", "claim_conflict", "regime_shift", "scope_change", "review_required"]
        },
        "affected_objects": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "transition": {
          "enum": ["no_op", "patch", "scoped_rerun", "trunk_rewrite", "human_review"]
        },
        "movement_jobs": {
          "$ref": "#/$defs/movementJobs"
        }
      }
    },
    "gate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gate_id", "condition", "reviewer", "required_decision", "status", "movement_jobs"],
      "properties": {
        "gate_id": {
          "type": "string"
        },
        "condition": {
          "type": "string"
        },
        "reviewer": {
          "type": "string"
        },
        "required_decision": {
          "type": "string"
        },
        "status": {
          "enum": ["open", "approved", "blocked", "not_required"]
        },
        "movement_jobs": {
          "$ref": "#/$defs/movementJobs"
        }
      }
    },
    "confidenceModel": {
      "type": "object",
      "additionalProperties": false,
