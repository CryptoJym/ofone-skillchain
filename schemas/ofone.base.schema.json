        "provenance_strength": {
          "$ref": "#/$defs/ordinal"
        },
        "source_independence": {
          "$ref": "#/$defs/ordinal"
        },
        "recency": {
          "$ref": "#/$defs/ordinal"
        },
        "mechanism_fit": {
          "$ref": "#/$defs/ordinal"
        },
        "contradiction_load": {
          "$ref": "#/$defs/ordinal"
        },
        "hidden_variable_risk": {
          "$ref": "#/$defs/ordinal"
        },
        "adversarial_risk": {
          "$ref": "#/$defs/ordinal"
        },
        "adapter_fit": {
          "$ref": "#/$defs/ordinal"
        },
        "movement_jobs": {
          "$ref": "#/$defs/movementJobs"
        }
      }
