{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cryptojym.github.io/ofone-skillchain/schemas/ofone.base.schema.json",
  "title": "OfOne Base Decision Map",
  "type": "object",
  "required": [
    "ofone_version",
    "mode",
    "charter",
    "adapter_projection",
    "scene",
    "evidence",
    "claims",
    "unknowns",
    "kill_tests",
    "triggers",
    "gates",
    "confidence_model",
    "decision_rendering"
  ],
  "properties": {
    "ofone_version": {
      "type": "string"
    },
    "mode": {
      "enum": ["Micro", "Map", "Audit"]
    },
    "charter": {
      "$ref": "#/$defs/charter"
    },
    "adapter_projection": {
      "$ref": "#/$defs/adapterProjection"
    },
    "scene": {
      "$ref": "#/$defs/scene"
    },
    "evidence": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidence"
      }
    },
    "claims": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/claim"
      }
    },
    "unknowns": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/unknown"
      }
    },
    "kill_tests": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/killTest"
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/edge"
      }
    },
    "loops": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/loop"
      }
    },
    "option_moves": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/optionMove"
      }
    },
    "triggers": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/trigger"
      }
    },
    "gates": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/gate"
      }
    },
    "confidence_model": {
      "$ref": "#/$defs/confidenceModel"
    },
    "decision_rendering": {
      "$ref": "#/$defs/decisionRendering"
    },
    "validator_result": {
      "$ref": "#/$defs/validatorResult"
    }
  },
  "$defs": {
    "movementJob": {
      "enum": ["BOUND", "GROUND", "CLAIM", "LINK", "TEST", "MOVE", "EVALUATE", "WARN", "TRIGGER", "GATE"]
    },
    "ordinal": {
      "enum": ["low", "medium", "high"]
    },
    "movementJobs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/movementJob"
      }
    },
    "charter": {
      "type": "object",
      "required": ["objective", "scope", "horizon", "stakes", "risk_tier", "movement_jobs"],
      "properties": {
        "objective": {
          "type": "string"
        },
        "scope": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "horizon": {
          "type": "string"
        },
        "stakes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "risk_tier": {
          "$ref": "#/$defs/ordinal"
        },
        "movement_jobs": {
          "$ref": "#/$defs/movementJobs"
        }
      }
    },
    "adapterProjection": {
      "type": "object",
      "required": ["primary", "axes", "movement_jobs"],
      "properties": {
        "primary": {
          "enum": ["strategic-agentic", "scientific-explanatory", "formal", "normative-evaluative", "hybrid", "provisional"]
        },
        "axes": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "movement_jobs": {
          "$ref": "#/$defs/movementJobs"
        }
      }
    },
    "scene": {
      "type": "object",
      "required": ["scene_id", "frames", "tokens", "subscenes", "state_variables", "observed_variables", "hidden_variables", "movement_jobs"],
      "properties": {
        "scene_id": {
          "type": "string"
        },
        "frames": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/frame"
          }
        },
        "tokens": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/token"
          }
        },
        "subscenes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/subscene"
          }
        },
        "state_variables": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "observed_variables": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "hidden_variables": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "movement_jobs": {
          "$ref": "#/$defs/movementJobs"
        }
      }
    },
    "frame": {
      "type": "object",
      "required": ["frame_id", "type", "assumptions"],
      "properties": {
        "frame_id": {
          "type": "string"
        },
        "type": {
          "enum": ["causal", "logical", "strategic", "normative", "temporal", "evidential"]
        },
        "assumptions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "subscene": {
      "type": "object",
      "required": ["subscene_id", "parent_scene", "purpose", "frames", "tokens", "entry_conditions", "exit_conditions", "movement_jobs"],
      "properties": {
        "subscene_id": {
          "type": "string"
        },
        "parent_scene": {
          "type": "string"
        },
        "purpose": {
          "enum": ["evidence_acquisition", "causal_mechanism", "option_decision", "review_gate", "proof_step", "stakeholder_context", "other"]
        },
        "frames": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tokens": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "entry_conditions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "exit_conditions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "movement_jobs": {
          "$ref": "#/$defs/movementJobs"
        }
      }
    },
    "token": {
      "type": "object",
      "required": ["token_id", "kind", "label"],
      "properties": {
        "token_id": {
          "type": "string"
        },
        "kind": {
          "enum": ["entity", "variable", "claim", "evidence", "uncertainty", "constraint", "option", "trigger", "gate", "unknown"]
        },
        "label": {
          "type": "string"
        }
      }
    },
    "evidence": {
      "type": "object",
      "required": ["evidence_id", "source", "span_or_locator", "provenance", "recency", "reliability", "permission", "content_hash", "retrieved_at", "extract", "source_owner", "chain_of_custody", "supports", "risks", "movement_jobs"],
      "properties": {
        "evidence_id": {
          "type": "string"
        },
        "source": {
          "enum": ["file", "url", "observation", "testimony", "simulation", "tool"]
        },
        "span_or_locator": {
          "type": "string"
        },
        "provenance": {
          "type": "string"
        },
        "recency": {
          "enum": ["current", "dated", "unknown"]
        },
        "reliability": {
          "$ref": "#/$defs/ordinal"
        },
        "permission": {
          "enum": ["internal", "public", "restricted"]
        },
        "content_hash": {
          "type": "string",
          "pattern": "^sha256:[a-fA-F0-9]{64}$|^unknown$"
        },
        "retrieved_at": {
          "type": "string"
        },
        "extract": {
          "type": "string"
        },
        "source_owner": {
          "type": "string"
        },
        "chain_of_custody": {
          "type": "string"
        },
        "supports": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "risks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "movement_jobs": {
          "$ref": "#/$defs/movementJobs"
        }
      }
    },
    "claim": {
      "type": "object",
      "required": ["claim_id", "text", "type", "supports", "contradicts", "depends_on", "confidence", "status", "review_gate", "movement_jobs"],
      "properties": {
        "claim_id": {
          "type": "string"
        },
        "text": {
          "type": "string"
        },
        "type": {
          "enum": ["descriptive", "causal", "predictive", "normative", "formal", "operational"]
        },
        "supports": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "contradicts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "depends_on": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "confidence": {
          "$ref": "#/$defs/claimConfidence"
        },
        "status": {
          "enum": ["active", "disputed", "superseded", "killed"]
        },
        "review_gate": {
          "type": "boolean"
        },
        "movement_jobs": {
          "$ref": "#/$defs/movementJobs"
        }
      }
    },
    "claimConfidence": {
      "type": "object",
      "required": ["level", "basis", "failure_modes"],
      "properties": {
        "level": {
          "$ref": "#/$defs/ordinal"
        },
        "basis": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": ["provenance", "independence", "recency", "mechanism_fit", "contradiction_load", "hidden_variable_risk", "adversarial_risk", "adapter_fit"]
          }
        },
        "failure_modes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "unknown": {
      "type": "object",
      "required": ["unknown_id", "kind", "description", "blocks", "resolution_move", "status", "movement_jobs"],
      "properties": {
        "unknown_id": {
          "type": "string"
        },
        "kind": {
          "enum": ["missing_evidence", "missing_measurement", "missing_claim", "missing_adapter", "unresolved_conflict", "unobserved_variable"]
        },
        "description": {
          "type": "string"
        },
        "blocks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "resolution_move": {
          "type": "string"
        },
        "status": {
          "enum": ["open", "resolved", "accepted_risk"]
        },
        "movement_jobs": {
          "$ref": "#/$defs/movementJobs"
        }
      }
    },
    "killTest": {
      "type": "object",
      "required": ["test_id", "target", "test_type", "condition", "falsifies", "movement_jobs"],
      "properties": {
        "test_id": {
          "type": "string"
        },
        "target": {
          "type": "string"
        },
        "test_type": {
          "enum": ["counterexample", "measurement", "replication", "countermodel", "stakeholder_objection", "constraint_violation", "adapter_conflict"]
        },
        "condition": {
          "type": "string"
        },
        "falsifies": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "movement_jobs": {
          "$ref": "#/$defs/movementJobs"
        }
      }
    },
    "edge": {
      "type": "object",
      "required": ["edge_id", "from", "to", "relation", "evidence_refs", "confidence", "movement_jobs"],
      "properties": {
        "edge_id": {
          "type": "string"
        },
        "from": {
          "type": "string"
        },
        "to": {
          "type": "string"
        },
        "relation": {
          "enum": ["causes", "constrains", "supports", "contradicts", "enables", "observes", "evaluates", "updates", "blocks", "depends_on"]
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "confidence": {
          "$ref": "#/$defs/ordinal"
        },
        "movement_jobs": {
          "$ref": "#/$defs/movementJobs"
        }
      }
    },
    "loop": {
      "type": "object",
      "required": ["loop_id", "type", "edges", "polarity", "delay", "gain", "control_points", "observable_cues", "failure_mode", "movement_jobs"],
      "properties": {
        "loop_id": {
          "type": "string"
        },
        "type": {
          "enum": ["reinforcing", "balancing", "measurement", "incentive", "learning", "contradiction", "review", "deception", "regime"]
        },
        "edges": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "polarity": {
          "enum": ["reinforcing", "balancing", "mixed", "unknown"]
        },
        "delay": {
          "enum": ["short", "medium", "long", "unknown"]
        },
        "gain": {
          "enum": ["low", "medium", "high", "unknown"]
        },
        "control_points": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "observable_cues": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "failure_mode": {
          "type": "string"
        },
        "movement_jobs": {
          "$ref": "#/$defs/movementJobs"
        }
      }
    },
    "optionMove": {
      "type": "object",
      "required": ["option_id", "move_type", "preconditions", "expected_effects", "tradeoffs", "blocking_unknowns", "review_gate", "movement_jobs"],
      "properties": {
        "option_id": {
          "type": "string"
        },
        "move_type": {
          "enum": ["act", "query", "test", "prove", "observe", "defer", "revise"]
        },
        "preconditions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "expected_effects": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tradeoffs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "blocking_unknowns": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "review_gate": {
          "type": "string"
        },
        "movement_jobs": {
          "$ref": "#/$defs/movementJobs"
        }
      }
    },
    "trigger": {
      "type": "object",
      "required": ["trigger_id", "condition", "affected_objects", "transition", "movement_jobs"],
      "properties": {
        "trigger_id": {
          "type": "string"
        },
        "condition": {
          "enum": ["new_evidence", "claim_conflict", "regime_shift", "scope_change", "review_required"]
        },
        "affected_objects": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "transition": {
          "enum": ["no_op", "patch", "scoped_rerun", "trunk_rewrite", "human_review"]
        },
        "movement_jobs": {
          "$ref": "#/$defs/movementJobs"
        }
      }
    },
    "gate": {
      "type": "object",
      "required": ["gate_id", "condition", "reviewer", "required_decision", "status", "movement_jobs"],
      "properties": {
        "gate_id": {
          "type": "string"
        },
        "condition": {
          "type": "string"
        },
        "reviewer": {
          "type": "string"
        },
        "required_decision": {
          "type": "string"
        },
        "status": {
          "enum": ["open", "approved", "blocked", "not_required"]
        },
        "movement_jobs": {
          "$ref": "#/$defs/movementJobs"
        }
      }
    },
    "confidenceModel": {
      "type": "object",
      "required": ["overall", "provenance_strength", "source_independence", "recency", "mechanism_fit", "contradiction_load", "hidden_variable_risk", "adversarial_risk", "adapter_fit", "movement_jobs"],
      "properties": {
        "overall": {
          "$ref": "#/$defs/ordinal"
        },
        "provenance_strength": {
          "$ref": "#/$defs/ordinal"
        },
        "source_independence": {
          "$ref": "#/$defs/ordinal"
        },
        "recency": {
          "$ref": "#/$defs/ordinal"
        },
        "mechanism_fit": {
          "$ref": "#/$defs/ordinal"
        },
        "contradiction_load": {
          "$ref": "#/$defs/ordinal"
        },
        "hidden_variable_risk": {
          "$ref": "#/$defs/ordinal"
        },
        "adversarial_risk": {
          "$ref": "#/$defs/ordinal"
        },
        "adapter_fit": {
          "$ref": "#/$defs/ordinal"
        },
        "movement_jobs": {
          "$ref": "#/$defs/movementJobs"
        }
      }
    },
    "decisionRendering": {
      "type": "object",
      "required": ["rendering_id", "summary", "recommendation", "confidence", "depends_on", "movement_jobs"],
      "properties": {
        "rendering_id": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "recommendation": {
          "type": "string"
        },
        "confidence": {
          "$ref": "#/$defs/ordinal"
        },
        "depends_on": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "movement_jobs": {
          "$ref": "#/$defs/movementJobs"
        }
      }
    },
    "validatorResult": {
      "type": "object",
      "required": ["passed", "checks"],
      "properties": {
        "passed": {
          "type": "boolean"
        },
        "checks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["check", "passed", "notes"],
            "properties": {
              "check": {
                "type": "string"
              },
              "passed": {
                "type": "boolean"
              },
              "notes": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}
