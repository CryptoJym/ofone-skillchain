{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cryptojym.github.io/ofone-skillchain/schemas/ofone.map.schema.json",
  "title": "OfOne Map Decision Map",
  "allOf": [
    { "$ref": "https://cryptojym.github.io/ofone-skillchain/schemas/ofone.base.schema.json" },
    {
      "type": "object",
      "required": [
        "ofone_version",
        "mode",
        "charter",
        "artifact_identity",
        "adapter_projection",
        "scene",
        "evidence",
        "claims",
        "unknowns",
        "kill_tests",
        "criteria",
        "tradeoff_surface",
        "temporal_model",
        "edges",
        "loops",
        "option_moves",
        "triggers",
        "gates",
        "confidence_model",
        "decision_rendering"
      ],
      "properties": {
        "mode": { "const": "Map" },
        "unknowns": { "type": "array" },
        "kill_tests": { "type": "array", "minItems": 1 },
        "criteria": { "type": "array", "minItems": 1 },
        "actors": { "type": "array" },
        "information_value": { "type": "array" },
        "lenses": { "type": "array" },
        "review_log": { "type": "array" },
        "edges": { "type": "array", "minItems": 1 },
        "loops": { "type": "array", "minItems": 1 },
        "option_moves": { "type": "array", "minItems": 1 }
      }
    }
  ]
}
