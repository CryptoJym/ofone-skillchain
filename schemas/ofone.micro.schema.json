{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cryptojym.github.io/ofone-skillchain/schemas/ofone.micro.schema.json",
  "title": "OfOne Micro Decision Map",
  "allOf": [
    { "$ref": "https://cryptojym.github.io/ofone-skillchain/schemas/ofone.base.schema.json" },
    {
      "type": "object",
      "required": [
        "ofone_version",
        "mode",
        "charter",
        "adapter_projection",
        "scene",
        "evidence",
        "claims",
        "unknowns",
        "kill_tests",
        "triggers",
        "gates",
        "confidence_model",
        "decision_rendering"
      ],
      "properties": {
        "mode": { "const": "Micro" },
        "evidence": { "type": "array", "minItems": 1 },
        "claims": { "type": "array", "minItems": 1 },
        "decision_rendering": {
          "type": "object",
          "required": ["rendering_id", "summary", "recommendation", "confidence", "depends_on", "movement_jobs"]
        }
      }
    }
  ]
}
