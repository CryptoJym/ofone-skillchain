{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cryptojym.github.io/ofone-skillchain/schemas/ofone.audit.schema.json",
  "title": "OfOne Audit Decision Map",
  "allOf": [
    { "$ref": "https://cryptojym.github.io/ofone-skillchain/schemas/ofone.base.schema.json" },
    {
      "type": "object",
      "required": [
        "ofone_version",
        "mode",
        "charter",
        "artifact_identity",
        "adapter_projection",
        "scene",
        "evidence",
        "claims",
        "unknowns",
        "kill_tests",
        "criteria",
        "tradeoff_surface",
        "actors",
        "temporal_model",
        "information_value",
        "lenses",
        "council_result",
        "review_log",
        "edges",
        "loops",
        "option_moves",
        "triggers",
        "gates",
        "confidence_model",
        "decision_rendering"
      ],
      "properties": {
        "mode": { "const": "Audit" },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "required": ["content_hash", "retrieved_at", "extract", "source_owner", "chain_of_custody"]
          }
        },
        "unknowns": { "type": "array", "minItems": 1 },
        "kill_tests": { "type": "array", "minItems": 1 },
        "criteria": { "type": "array", "minItems": 1 },
        "actors": { "type": "array", "minItems": 1 },
        "information_value": { "type": "array", "minItems": 1 },
        "lenses": { "type": "array", "minItems": 1 },
        "review_log": { "type": "array" },
        "edges": { "type": "array", "minItems": 1 },
        "loops": {
          "type": "array",
          "minItems": 1,
          "items": {
            "required": ["polarity", "delay", "gain", "control_points", "observable_cues"]
          }
        },
        "option_moves": { "type": "array", "minItems": 1 },
        "decision_rendering": {
          "type": "object",
          "required": ["rendering_id", "summary", "recommendation", "confidence", "depends_on", "movement_jobs"]
        }
      }
    }
  ]
}
